# Streamlit secrets — local: copy to .streamlit/secrets.toml; Cloud: paste into App settings → Secrets
SUPABASE_URL = "https://<PROJECT_REF>.supabase.co"
SUPABASE_KEY = "<anon or publishable key — never commit>"

# Optional toggles
DB_BACKEND = "supabase"            # "supabase" | "sqlite"
SUPABASE_PHOTOS_BUCKET = "photos"
SUPABASE_OUTPUTS_BUCKET = "material-gate"
